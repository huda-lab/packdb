# name: test/sql/decide_explain.test
# description: Test EXPLAIN output for DECIDE operator
# group: [decide]

statement ok
CREATE TABLE items (id INTEGER, weight INTEGER, value INTEGER, category VARCHAR);

statement ok
INSERT INTO items VALUES (1, 10, 60, 'A'), (2, 20, 100, 'B'), (3, 30, 120, 'A');

# ===================================================================
# 1. Basic EXPLAIN — verify DECIDE node and all sections appear
# ===================================================================

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*DECIDE.*

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*Variables.*x.*

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*MAXIMIZE.*

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*Constraints.*

# Verify actual constraint content appears (SUM expression)
query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*sum.*

# ===================================================================
# 2. MINIMIZE variant
# ===================================================================

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * value) >= 100 MINIMIZE SUM(x * weight);
----
physical_plan	<REGEX>:.*MINIMIZE.*

# ===================================================================
# 3. Multiple constraints — verify splitting
# ===================================================================

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 AND x >= 0 MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*Constraints.*

# ===================================================================
# 4. INTEGER variable type
# ===================================================================

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS INTEGER SUCH THAT x <= 5 AND SUM(x * weight) <= 100 MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*DECIDE.*

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS INTEGER SUCH THAT x <= 5 AND SUM(x * weight) <= 100 MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*Variables.*x.*

# ===================================================================
# 5. Multiple decision variables
# ===================================================================

query II
EXPLAIN SELECT id, x, y FROM items DECIDE x IS BOOLEAN, y IS INTEGER SUCH THAT SUM(x * weight) <= 50 AND y <= 3 AND SUM(y) <= 5 MAXIMIZE SUM(x * value + y);
----
physical_plan	<REGEX>:.*DECIDE.*

query II
EXPLAIN SELECT id, x, y FROM items DECIDE x IS BOOLEAN, y IS INTEGER SUCH THAT SUM(x * weight) <= 50 AND y <= 3 AND SUM(y) <= 5 MAXIMIZE SUM(x * value + y);
----
physical_plan	<REGEX>:.*Variables.*

# ===================================================================
# 6. WHEN clause display
# ===================================================================

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 WHEN category = 'A' MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*WHEN.*

# ===================================================================
# 7. PER clause display
# ===================================================================

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x) <= 2 PER category MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*PER.*

# ===================================================================
# 8. WHEN + PER combined
# ===================================================================

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 WHEN value > 50 PER category MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*WHEN.*

query II
EXPLAIN SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 WHEN value > 50 PER category MAXIMIZE SUM(x * value);
----
physical_plan	<REGEX>:.*PER.*

# ===================================================================
# 9. EXPLAIN (FORMAT JSON) — verify structure
# ===================================================================

statement ok
pragma explain_output='optimized_only'

# DECIDE node name in JSON
query II
EXPLAIN (FORMAT JSON) SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
logical_opt	<REGEX>:.*"name": "DECIDE".*

# Variables key in JSON
query II
EXPLAIN (FORMAT JSON) SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
logical_opt	<REGEX>:.*"Variables".*

# Objective key in JSON
query II
EXPLAIN (FORMAT JSON) SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
logical_opt	<REGEX>:.*"Objective".*

# Constraints key in JSON
query II
EXPLAIN (FORMAT JSON) SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
logical_opt	<REGEX>:.*"Constraints".*

# ===================================================================
# 10. EXPLAIN ANALYZE — verify execution + DECIDE appears
# ===================================================================

query II
EXPLAIN ANALYZE SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
analyzed_plan	<REGEX>:.*DECIDE.*

# Verify timing info is present in EXPLAIN ANALYZE
query II
EXPLAIN ANALYZE SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
analyzed_plan	<REGEX>:.*Rows.*

# ===================================================================
# 11. EXPLAIN ANALYZE (FORMAT JSON) — verify JSON output
# ===================================================================

query II
EXPLAIN (ANALYZE, FORMAT JSON) SELECT id, x FROM items DECIDE x IS BOOLEAN SUCH THAT SUM(x * weight) <= 50 AND x <= 1 MAXIMIZE SUM(x * value);
----
analyzed_plan	<REGEX>:.*DECIDE.*


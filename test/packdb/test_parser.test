# name: test/packdb/test_parser.test
# description: Test PackDB's Parser
# group: [packdb]

statement ok
ATTACH 'build/packdb.db' AS packdb;

statement ok
SET search_path = 'packdb,main';

# Parse REAL
statement ok
SELECT l_quantity FROM lineitem DECIDE x SUCH THAT x IS REAL MAXIMIZE SUM(x*l_quantity) LIMIT 1;

# Parse INTEGER
statement ok
SELECT l_quantity FROM lineitem DECIDE x SUCH THAT x IS INTEGER MAXIMIZE SUM(x*l_quantity) LIMIT 1;

# Parse BINARY
statement ok
SELECT l_quantity FROM lineitem DECIDE x SUCH THAT x IS BINARY MAXIMIZE SUM(x*l_quantity) LIMIT 1;

# No SUCH THAT
statement error
SELECT l_quantity FROM lineitem DECIDE x MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
Parser Error: syntax error at or near "MAXIMIZE"

# No DECIDE variable
statement error
SELECT l_quantity FROM lineitem DECIDE SUCH THAT x IS BINARY MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
Parser Error: syntax error at or near "SUCH"

# No objective
statement error
SELECT l_quantity FROM lineitem DECIDE x SUCH THAT x IS BINARY MAXIMIZE LIMIT 1;
----
Parser Error: syntax error at or near "LIMIT"

# Unknown variable type
statement error
SELECT l_quantity FROM lineitem DECIDE x SUCH THAT x IS CONTINUOUS MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
Parser Error: syntax error at or near "CONTINUOUS"
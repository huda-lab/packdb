# name: test/packdb/test_binder.test
# description: Test PackDB's Binder
# group: [packdb]

statement ok
ATTACH 'build/packdb.db' AS packdb;

statement ok
SET search_path = 'packdb,main';

# DECIDE variable conflicts existing column
statement error
SELECT * FROM lineitem DECIDE l_quantity, x SUCH THAT x IN (1,2,3) MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: DECIDE variable '[a-zA-Z_][a-zA-Z0-9_]*' conflicts with an existing column name.*

# Duplicated DECIDE variables
statement error
SELECT * FROM lineitem DECIDE x, x SUCH THAT x IN (1,2,3) MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: Duplicate DECIDE variable name '[a-zA-Z_][a-zA-Z0-9_]*'.*

# Unknown DECIDE variable
statement error
SELECT * FROM lineitem DECIDE y SUCH THAT x IN (1,2,3) MAXIMIZE SUM(x) LIMIT 1;
----
<REGEX>:Binder Error: Only DECIDE variables are allowed for IN expression, found.*

# Unsupported ExpressionClass::OPERATOR
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT x IS NULL MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: SUCH THAT constraint clause does not support.*

# Bind IN
statement ok
SELECT * FROM lineitem DECIDE x SUCH THAT x IN (1,2,3) MAXIMIZE SUM(x*l_quantity) LIMIT 1;

# DECIDE variables only allowed in COMPARE_IN
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) IN (1,2,3) MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: Only DECIDE variables are allowed for IN expression, found.*

# Bind BETWEEN
statement ok
SELECT * FROM lineitem DECIDE x SUCH THAT x BETWEEN 2 AND 4 MAXIMIZE SUM(x*l_quantity) LIMIT 1;

# Bind IS variable_type
statement ok
SELECT * FROM lineitem DECIDE x SUCH THAT x IS REAL MAXIMIZE SUM(x*l_quantity) LIMIT 1;

# LHS is not decide variable
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT l_quantity <= 5 MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: SUCH THAT clause: Column '[a-zA-Z_][a-zA-Z0-9_]*' must be one of the DECIDE variables.*

# LHS is not SUM function
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT AVG(x) <= 5 MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: SUCH THAT clause does not support left-hand side function '[a-zA-Z_][a-zA-Z0-9_]*', only SUM is allowed.*

# Not multiplication in top argument of SUM
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x+x) <= 5 MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: Either SUM\(x\), SUM\(f\(a\)\*x\) or SUM\(x\*f\(a\)\) is allowed, found.*

# Top argument is not DECIDE variables
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(l_quantity) <= 5  MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: SUM function does not have DECIDE variables, found.*

# More than one occurrence of DECIDE variables
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM((l_quantity+x)*x) <= 5  MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: More than one occurrence of DECIDE variables in a SUM function, found.*

# No DECIDE variables as a linear factor
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(l_quantity*(l_extendedprice+x)) <= 5 MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: SUM function does not have DECIDE variables as linear factors, found.*

# Bad comparison sign
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) < 5 MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: SUCH THAT constraint clause does not support.*

# Bind between
statement ok
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) BETWEEN 2 AND 3 MAXIMIZE SUM(x*l_quantity) LIMIT 1;

# Bind IS variable_type
statement ok
SELECT * FROM lineitem DECIDE x SUCH THAT x IS REAL MAXIMIZE SUM(x*l_quantity) LIMIT 1;

# SUM Between has non-scalar expression
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) BETWEEN l_quantity and 1 MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: SUM cannot be between an expression that is not a scalar or contains DECIDE variables, found.*

# DECIDE variable Between contains DECIDE variables
statement error
SELECT * FROM lineitem DECIDE x, y SUCH THAT x BETWEEN y and 1 MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: DECIDE variable cannot be between an expression with DECIDE variables.*

# IN Right-hand side has DECIDE variables
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT x IN (1,2,x) MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: IN Right-hand side cannot contain DECIDE variables, found.*

# SUM Right-hand side has non-scalar expression
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) <= l_quantity MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: SUM cannot be compared an expression that is not a scalar or contains DECIDE variables, found.*

# DECIDE variable Right-hand side has DECIDE variables
statement error
SELECT * FROM lineitem DECIDE x, y SUCH THAT x <= y MAXIMIZE SUM(x*l_quantity) LIMIT 1;
----
<REGEX>:Binder Error: DECIDE variable cannot be compared to an expression with DECIDE variables, found.*

# SUM Equal Right-hand side has non-scalar expression
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) = l_quantity MAXIMIZE SUM(x) LIMIT 1;
----
<REGEX>:Binder Error: SUM cannot be equal to an expression that is not a scalar or contains DECIDE variables, found.*

# Unsupported objective 1
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) <= 3 MAXIMIZE SUM(x*l_quantity)+3 LIMIT 1;
----
<REGEX>:Binder Error: \[MAXIMIZE\|MINIMIZE\] clause does not support function '\+', only SUM is allowed.*

# Unsupported objective 2
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) <= 3 MAXIMIZE l_quantity LIMIT 1;
----
<REGEX>:Binder Error: \[MAXIMIZE\|MINIMIZE\] clause does not support '[a-zA-Z_][a-zA-Z0-9_]*'.*

# Bind subquery
statement ok
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) <= (SELECT SUM(l_quantity) FROM lineitem) MAXIMIZE SUM(x) LIMIT 1;

# Non-scalar subquery
statement error
SELECT * FROM lineitem DECIDE x SUCH THAT SUM(x) <= (SELECT l_quantity+x FROM lineitem) MAXIMIZE SUM(x) LIMIT 1;
----
<REGEX>:Binder Error: SUM cannot be compared an expression that is not a scalar or contains DECIDE variables, found.*
SELECT l_orderkey, l_linenumber, l_quantity, l_extendedprice,
       l_discount, x
FROM lineitem
WHERE l_orderkey < {SCALE}
DECIDE x IS BOOLEAN
SUCH THAT SUM(x * l_quantity) <= 5000
    AND SUM(x) <= 500
    AND SUM(x * l_extendedprice * l_discount) <= 50000
MAXIMIZE SUM(x * l_extendedprice * (1 - l_discount));
